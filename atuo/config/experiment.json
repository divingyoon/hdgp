{
  "project": {
    "isaaclab_root": "../../../IsaacLab",
    "skillblender_root": "../..",
    "log_root": "../../log/rsl_rl"
  },
  "env": {
    "ISAAC_SIM_DISABLE_SHARED_MEMORY": "1",
    "OMNI_DISABLE_SHARED_MEMORY": "1",
    "CARB_DISABLE_SHARED_MEMORY": "1"
  },
  "train": {
    "task": "grasp2g-v1",
    "agent": "rsl_rl_dual_cfg_entry_point",
    "train_script": "../../scripts/reinforcement_learning/rsl_rl/train.py",
    "base_args": ["--headless"],
    "num_envs": null,
    "seed": 42,
    "max_iterations": null
  },
  "eval": {
    "eval_script": "../eval_grasp2g_metrics.py",
    "base_args": ["--headless"],
    "num_episodes": 100,
    "num_envs": 1,
    "goal_threshold": 0.8,
    "lift_threshold": 0.1,
    "goal_dist_threshold": 0.05,
    "seed": 123
  },
  "success_criteria": {
    "lift_success_min": 0.0,
    "hold_success_min": 0.0,
    "goal_success_min": 0.0,
    "goal_track_success_min": 0.0,
    "goal_dist_mean_max": 0.05,
    "success_rate_min": 0.5
  },
  "analysis_thresholds": {
    "min_train_reward": 50.0,
    "collapse_ratio": 0.7,
    "entropy_min": 0.005,
    "lift_success_min": 0.4,
    "goal_track_success_min": 0.4,
    "goal_dist_mean_max": 0.05,
    "hand_closure_min": 0.05,
    "hand_closure_premature_max": 0.5,
    "reaching_stuck_dist": 0.12,
    "phase_stuck_max": 0.5,
    "reward_conflict_ratio": 0.5,
    "eef_dist_delta_min": 0.0001,
    "phase_0_stuck_threshold": 0.1,
    "bimanual_phase_diff_max": 0.3
  },
  "analysis_rules_path": "failure_rules.json",
  "llm": {
    "enabled": true,
    "provider": "ollama",
    "model": "qwen2.5:14b",
    "temperature": 0.3,
    "max_tokens": 2048,
    "api_base": "http://localhost:11434"
  },
  "llm_refine_loop": {
    "enabled": true,
    "freeze_analysis_script": "../../scripts/tools/freeze_run_analysis.py",
    "out_dir": "../../log/analysis_llm",
    "report_verbosity": "long",
    "gemini": true,
    "gemini_cmd": "gemini",
    "gemini_no_browser": false
  },
  "override_policy": {
    "allowed_overrides": [
      "env.rewards.",
      "env.terminations.",
      "env.curriculum.",
      "env.phase_stability_reach_steps",
      "env.phase_stability_grasp_steps",
      "env.phase_stability_lift_steps",
      "env.phase_demotion_enabled",
      "env.phase_demotion_margin",
      "env.episode_length_s",
      "env.grasp2g_target_offset",
      "env.reach_switch_threshold",
      "env.reach_switch_hold_steps",
      "env.grasp_switch_threshold",
      "env.grasp_switch_hold_steps",
      "env.reach_soft_gate_near",
      "env.reach_soft_gate_far",
      "env.grasp_soft_gate_near",
      "env.grasp_soft_gate_far",
      "env.grasp_soft_prefactor",
      "env.grasp_orientation_std",
      "env.grasp_orientation_gate_min_reward",
      "env.grasp_orientation_gate_full_reward",
      "env.grasp_displacement_free_threshold",
      "env.grasp_displacement_suppress_scale",
      "env.transfer_soft_height_lo",
      "env.transfer_soft_height_hi",
      "env.transfer_switch_height",
      "env.transfer_switch_hold_steps",
      "env.reach_displacement_free_threshold",
      "env.reach_displacement_suppress_scale",
      "env.terminations.cup_tipping.params.max_tilt_deg"
    ]
  },
  "run_policy": {
    "max_runs": 5,
    "stop_on_success": true,
    "train_chunk_iterations": 1000,
    "max_total_iterations": 10000,
    "stop_on_collapse": true,
    "stream_logs": true
  }
}
